{
  "manifest_version": 3,
  "name": "PhishX Detector",
  "version": "1.0",

  "permissions": ["tabs", "activeTab", "scripting"],
  
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"]
    }
  ]
  }
    
  
 
